	<queryString>
		<![CDATA[SELECT
     *,
     productos.`idproducto` AS productos_idproducto,
     productos.`nombre` AS productos_nombre,
     productos.`stock` AS productos_stock,
     productos.`idCategoria` AS productos_idCategoria,
     productos.`precioV` AS productos_precioV,
     entrada.`idproveedor` AS entrada_idproveedor,
     entrada.`precioE` AS entrada_precioE,
     entrada.`precioV` AS entrada_precioV,
     entrada.`total` AS entrada_total
FROM
     `entrada` entrada INNER JOIN `productos` productos ON entrada.`idproducto` = productos.`idproducto`]]>
	</queryString>
